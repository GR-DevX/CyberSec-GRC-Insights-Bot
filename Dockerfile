# 1. Базовый образ
# Используем официальный образ Python 3.11 в "slim" версии для экономии места.
FROM python:3.11-slim

# 2. Установка рабочей директории
# Все последующие команды будут выполняться в этой папке внутри контейнера.
WORKDIR /app

# 3. Копирование файла с зависимостями
COPY requirements.txt .

# 4. Установка зависимостей
# --no-cache-dir не сохраняет кэш, что уменьшает размер итогового образа.
# Устанавливаем все зависимости из одного файла для корректного разрешения конфликтов.
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копирование кода приложения
COPY main.py .

# 6. Команда для запуска
# Запускаем скрипт. Флаг -u отключает буферизацию вывода,
# чтобы логи сразу появлялись в `docker logs`.
CMD ["python", "-u", "main.py"]